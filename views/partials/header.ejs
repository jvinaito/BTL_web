<header class="shadow-sm sticky-top bg-white">
  <div class="bg-primary text-white py-2 d-none d-md-block">
    <div class="container d-flex justify-content-between align-items-center small">
      <div><i class="fa-solid fa-truck me-2"></i>Free shipping over $150</div>
      <div class="d-flex gap-3">
        <% if (user) { %>
          <!-- Dropdown menu với avatar -->
          <div class="dropdown">
            <a href="#" class="d-flex align-items-center text-white text-decoration-none dropdown-toggle" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
            
              <img src="https://i.pravatar.cc/150?u=<%= user._id %>" class="rounded-circle me-2" width="32" height="32">
              <span><%= user.firstName %></span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
              <li><a class="dropdown-item" href="/orders/history">History</a></li>
              <li><a class="dropdown-item" href="/orders/profile">Profile</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item" href="/auth/logout">Logout</a></li>
            </ul>
          </div>
        <% } else { %>
          <a href="/auth/login" class="text-white text-decoration-none">Login</a>
          <a href="/auth/signup" class="text-white text-decoration-none">Register</a>
        <% } %>
      </div>
    </div>
  </div>

  <nav class="navbar navbar-expand-lg bg-white border-bottom py-3">
    <div class="container">
      <a class="navbar-brand d-flex align-items-center fw-bold" href="/" style="font-family: 'Luckiest Guy', cursive; font-size: 2.2rem; letter-spacing: 2px;">
        <span class="text-primary">T</span>
        <span class="text-danger">O</span>
        <span class="text-warning">Y</span>
        <span class="text-success">S</span>
      </a>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse justify-content-center" id="navbarNav">
        <ul class="navbar-nav fw-bold">
          <li class="nav-item"><a class="nav-link text-dark mx-2" href="/">Home</a></li>
          <li class="nav-item"><a class="nav-link text-dark mx-2" href="/products">Shop</a></li>
          <li class="nav-item"><a class="nav-link text-dark mx-2" href="/contact">Contact</a></li>
        </ul>
      </div>

      <div class="d-flex align-items-center gap-3">
        <div class="input-group input-group-sm d-none d-md-flex" style="width: 200px;">
          <input type="text" class="form-control rounded-pill-start border-end-0 bg-light" placeholder="Search">
          <span class="input-group-text bg-light border-start-0 rounded-pill-end"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
        </div>
        <a href="/orders/cart" class="text-dark position-relative">
          <i class="fa-solid fa-cart-shopping fs-4"></i>
          <% if (user && user.cartCount) { %>
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"><%= user.cartCount %></span>
          <% } %>
        </a>
      </div>
    </div>
  </nav>
</header>