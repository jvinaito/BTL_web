<% title = 'Home' %>

<section class="hero-section bg-light py-5">
  <div class="container">
    <div class="row align-items-center"> 
      <div class="col-md-6">
        <img src="https://i.ibb.co/j9VqSJfK/image.png" class="img-fluid" alt="hero image">
      </div>
      <div class="col-md-6 text-center text-md-start">
        <h1 class="display-4 fw-bold text-info">Play, learn, & grow!</h1>
        <p class="lead text-muted">Crafting smiles with every toy, made for learning, fun, and growth</p>
        <a href="/products" class="btn btn-warning btn-lg rounded-pill px-4 fw-bold shadow-sm">Shop now</a>
      </div>
    </div>
  </div>
</section>

<!-- Best Seller -->
<section class="py-5">
  <div class="container">
    <h2 class="text-center mb-4 fw-bold">Best Seller</h2>
    <div class="row g-3">
      <% bestSellers.forEach(product => { %>
        <div class="col-6 col-md-3">
          <div class="card h-100 border-light-subtle shadow-sm p-2 position-relative rounded-4">
            <% if (product.discount > 0) { %>
              <span class="badge bg-danger position-absolute m-2 px-2" style="font-size:10px; z-index:1">SALE</span>
            <% } %>
            <a href="/products/<%= product._id %>" class="text-decoration-none">
              <img src="<%= product.imageUrl %>" class="card-img p-2 rounded-4">
              <div class="card-body p-1 text-center d-flex flex-column">
                <p class="small fw-bold mb-1 text-truncate text-dark"><%= product.name %></p>
                <div class="mb-2">
                  <span class="<%= product.discount > 0 ? 'text-success' : 'text-dark' %> fw-bold">$<%= product.salePrice %></span>
                  <% if (product.discount > 0) { %>
                    <small class="text-muted text-decoration-line-through ms-1">$<%= product.originalPrice %></small>
                  <% } %>
                </div>
              </div>
            </a>
            <button class="btn btn-dark btn-sm rounded-pill py-1 w-100 mt-auto add-to-cart" data-id="<%= product._id %>" style="font-size: 12px">
              <i class="fa-solid fa-cart-shopping me-1"></i> Add to Cart
            </button>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

