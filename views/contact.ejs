<% title = 'Contact' %>

<div class="container py-5">
  <h2 class="fw-bold mb-5">Contact</h2>

  <div class="row g-4 mb-5 text-center">
    <div class="col-md-4">
      <div class="card h-100 border-0 shadow-sm rounded-4 p-4">
        <div class="card-body">
          <i class="fa-solid fa-phone fs-1 text-info mb-3"></i>
          <h5 class="fw-bold">Phone number</h5>
          <p class="text-muted mb-0 small">123-456-7868</p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card h-100 border-0 shadow-sm rounded-4 p-4">
        <div class="card-body">
          <i class="fa-solid fa-envelope fs-1 text-info mb-3"></i>
          <h5 class="fw-bold">Email</h5>
          <p class="text-muted mb-0 small">Info@example.com</p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card h-100 border-0 shadow-sm rounded-4 p-4">
        <div class="card-body">
          <i class="fa-solid fa-location-dot fs-1 text-info mb-3"></i>
          <h5 class="fw-bold">Address place</h5>
          <p class="text-muted mb-0 small">1930 marigold lane, way<br>Miami, Florida USA</p>
        </div>
      </div>
    </div>
  </div>

 
