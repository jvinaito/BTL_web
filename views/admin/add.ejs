<% title = product ? 'Edit Product' : 'Add Product' %>

<div class="container py-5">
  <div class="bg-white p-5 rounded-5 shadow-sm">
    <h4 class="fw-bold text-info mb-4"><%= product ? 'Edit' : 'Add new' %> product</h4>
    
    <form id="productForm" method="POST" action="<%= product ? '/admin/products/' + product._id + '?_method=PUT' : '/admin/products' %>">
      <div class="row g-4">
        <div class="col-md-6">
          <div class="mb-4">
            <label class="form-label fw-bold small">Name</label>
            <input type="text" name="name" class="form-control border-0 bg-light py-2 rounded-3" value="<%= product ? product.name : '' %>" placeholder="Md" required>
          </div>
          <div class="mb-4">
            <label class="form-label fw-bold small">Stock</label>
            <input type="number" name="stock" class="form-control border-0 bg-light py-2 rounded-3" value="<%= product ? product.stock : '' %>" placeholder="100">
          </div>
          <div class="mb-4">
            <label class="form-label fw-bold small">Discount (%)</label>
            <input type="number" name="discount" id="discount" class="form-control border-0 bg-light py-2 rounded-3" value="<%= product ? product.discount : '0' %>" placeholder="0" min="0" max="100">
          </div>
          <div class="mb-4">
            <label class="form-label fw-bold small">Brand</label>
            <input type="text" name="brand" class="form-control border-0 bg-light py-2 rounded-3" value="<%= product ? product.brand : '' %>" placeholder="Brand name">
          </div>
          <div class="mb-4">
            <label class="form-label fw-bold small">Age range</label>
            <input type="text" name="ageRange" class="form-control border-0 bg-light py-2 rounded-3" value="<%= product ? product.ageRange : '' %>" placeholder="0-3 years">
          </div>
        </div>

        <div class="col-md-6">
          <div class="mb-4">
            <label class="form-label fw-bold small">Category</label>
            <select name="category" class="form-select border-0 bg-light py-2 rounded-3" required>
              <option value="">Select category</option>
              <% categories.forEach(cat => { %>
                <option value="<%= cat._id %>" <%= product && product.category && product.category._id == cat._id ? 'selected' : '' %>>
                  <%= cat.name %>
                </option>
              <% }) %>
            </select>
          </div>
          <div class="mb-4">
            <label class="form-label fw-bold small">Original price ($)</label>
            <input type="number" step="0.01" name="originalPrice" id="originalPrice" class="form-control border-0 bg-light py-2 rounded-3" value="<%= product ? product.originalPrice : '' %>" placeholder="0.00" required>
          </div>
          
          <div class="mb-4">
            <label class="form-label fw-bold small">Gender</label>
            <select name="gender" class="form-select border-0 bg-light py-2 rounded-3">
              <option value="Unisex" <%= !product || product.gender === 'Unisex' ? 'selected' : '' %>>Unisex</option>
              <option value="Boy" <%= product && product.gender === 'Boy' ? 'selected' : '' %>>Boy</option>
              <option value="Girl" <%= product && product.gender === 'Girl' ? 'selected' : '' %>>Girl</option>
            </select>
          </div>
          <div class="mb-4">
            <label class="form-label fw-bold small">Description</label>
            <textarea name="description" class="form-control border-0 bg-light py-2 rounded-3" rows="1" placeholder="Short description"><%= product ? product.description : '' %></textarea>
          </div>
        </div>
      </div>

      <!-- Input ẩn để gửi salePrice -->
      <input type="hidden" name="salePrice" id="salePriceHidden" value="<%= product ? product.salePrice : '' %>">

      <div class="row mt-4 align-items-end">
        <div class="col-md-5">
          <div class="mb-4">
            <label class="form-label fw-bold small">Image URL</label>
            <input type="text" name="imageUrl" class="form-control border-0 bg-light py-2 rounded-3" placeholder="https://example.com/image.jpg" value="<%= product ? product.imageUrl : '' %>">
          </div>
          <div class="text-muted small">Nhập đường dẫn ảnh (có thể dùng link từ ImgBB, Gravatar, v.v.)</div>
        </div>
        
        <div class="col-md-7 text-end">
          <a href="/admin/products" class="btn btn-link text-dark text-decoration-none fw-bold me-4">Cancel</a>
          <button type="submit" class="btn btn-info text-white px-5 py-3 rounded-3 fw-bold shadow-sm" style="background-color: #00bcd4; border: none;">
            Save Changes
          </button>
        </div>
      </div>
    </form>
  </div>
</div>

<script>
  (function() {
    const form = document.getElementById('productForm');
    const originalPriceInput = document.getElementById('originalPrice');
    const discountInput = document.getElementById('discount');
    const salePriceHidden = document.getElementById('salePriceHidden');

    form.addEventListener('submit', function(e) {
      // Lấy giá trị
      let original = parseFloat(originalPriceInput.value);
      let discount = parseFloat(discountInput.value);

      // Kiểm tra originalPrice
      if (isNaN(original) || original <= 0) {
        e.preventDefault();
        alert('Original price phải là số dương lớn hơn 0.');
        return;
      }

      // Kiểm tra discount, nếu không hợp lệ hoặc rỗng thì gán 0
      if (isNaN(discount) || discount < 0) {
        discount = 0;
      }
      if (discount > 100) {
        e.preventDefault();
        alert('Discount không được vượt quá 100%.');
        return;
      }

      // Tính salePrice
      let salePrice = original * (1 - discount / 100);
      // Làm tròn 2 chữ số thập phân
      salePrice = Math.round(salePrice * 100) / 100;

      // Đảm bảo salePrice không âm
      if (salePrice < 0) salePrice = 0;

      // Gán vào input ẩn
      salePriceHidden.value = salePrice;
    });
  })();
</script>