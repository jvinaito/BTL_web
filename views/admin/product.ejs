<% title = 'Manage Products' %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div class="d-flex align-items-center gap-3">
    <span class="fw-bold">All Products (<%= totalProducts %>)</span>
    <a href="/admin/products/add" class="btn btn-primary btn-sm rounded-pill px-3 fw-bold">ADD NEW +</a>
  </div>
  <div class="d-flex gap-3 align-items-center">
    <!-- Form tìm kiếm -->
    <form method="GET" action="/admin/products" class="d-flex gap-2">
      <div class="input-group input-group-sm" style="width: 250px;">
        <input type="text" name="search" class="form-control border-end-0 shadow-none" placeholder="Search by product name..." value="<%= search %>">
        <button class="btn btn-light border-start-0" type="submit">
          <i class="fa-solid fa-magnifying-glass"></i>
        </button>
      </div>
    </form>
    <!-- Bộ lọc trạng thái -->
    <select class="form-select form-select-sm" style="width: 150px;" onchange="location = this.value;">
      <option value="/admin/products?status=all&search=<%= encodeURIComponent(search) %>" <%= status === 'all' ? 'selected' : '' %>>All Status</option>
      <option value="/admin/products?status=Active&search=<%= encodeURIComponent(search) %>" <%= status === 'Active' ? 'selected' : '' %>>Active</option>
      <option value="/admin/products?status=Out of Stock&search=<%= encodeURIComponent(search) %>" <%= status === 'Out of Stock' ? 'selected' : '' %>>Out of Stock</option>
    </select>
    <i class="fa-solid fa-filter"></i>
  </div>
</div>

<div class="table-responsive">
  <table class="table table-hover align-middle">
    <thead>
      <tr class="text-muted small border-bottom">
        <th class="fw-normal py-3">Product</th>
        <th class="fw-normal">Category</th>
        <th class="fw-normal">Stock</th>
        <th class="fw-normal">Price</th>
        <th class="fw-normal">Status</th>
        <th class="fw-normal text-center">Actions</th>
      </tr>
    </thead>
    <tbody class="small">
      <% products.forEach(product => { %>
      <tr>
        <td>
          <div class="d-flex align-items-center gap-2">
            <img src="<%= product.imageUrl || '/images/placeholder.png' %>" style="width: 40px; height: 40px; object-fit: cover;" class="rounded-3">
            <span class="fw-bold"><%= product.name %></span>
          </div>
        </td>
        <td><%= product.category ? product.category.name : 'N/A' %></td>
        <td><%= product.stock %></td>
        <td>$<%= product.salePrice.toFixed(2) %></td>
        <td>
          <span class="badge rounded-pill <%= product.status === 'Active' ? 'bg-success-subtle text-success' : 'bg-danger-subtle text-danger' %> px-3">
            <%= product.status %>
          </span>
        </td>
        <td class="text-center">
          <div class="d-flex gap-2 justify-content-center">
            <a href="/admin/products/edit/<%= product._id %>" class="btn btn-sm btn-outline-secondary">
              <i class="fa-solid fa-pen"></i>
            </a>
            <form action="/admin/products/<%= product._id %>?_method=DELETE" method="POST" style="display:inline;">
              <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this product?')">
                <i class="fa-solid fa-trash"></i>
              </button>
            </form>
          </div>
        </td>
      </tr>
      <% }) %>
      <% if (products.length === 0) { %>
      <tr>
        <td colspan="6" class="text-center py-4">No products found.</td>
      </tr>
      <% } %>
    </tbody>
  </table>
</div>

<!-- Phân trang -->
<% if (totalPages > 1) { %>
<div class="d-flex justify-content-between align-items-center mt-4 small text-muted">
  <div>
    Showing <%= (currentPage - 1) * limit + 1 %> to <%= Math.min(currentPage * limit, totalProducts) %> of <%= totalProducts %> entries
  </div>
  <nav>
    <ul class="pagination pagination-sm mb-0">
      <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
        <a class="page-link" href="?page=<%= currentPage - 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %><%= status && status !== 'all' ? '&status=' + encodeURIComponent(status) : '' %>">
          <i class="fa-solid fa-chevron-left"></i>
        </a>
      </li>
      <% for (let i = 1; i <= totalPages; i++) { %>
        <li class="page-item <%= i === currentPage ? 'active' : '' %>">
          <a class="page-link" href="?page=<%= i %><%= search ? '&search=' + encodeURIComponent(search) : '' %><%= status && status !== 'all' ? '&status=' + encodeURIComponent(status) : '' %>"><%= i %></a>
        </li>
      <% } %>
      <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
        <a class="page-link" href="?page=<%= currentPage + 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %><%= status && status !== 'all' ? '&status=' + encodeURIComponent(status) : '' %>">
          <i class="fa-solid fa-chevron-right"></i>
        </a>
      </li>
    </ul>
  </nav>
</div>
<% } %>