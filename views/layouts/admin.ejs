<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title ? title + ' - ' : '' %>Admin | Rainbow Rattles</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    :root { --admin-blue: #0084aa; --admin-pink: #e91e63; }
    .bg-admin-blue { background-color: var(--admin-blue) !important; }
    .nav-link { color: rgba(255,255,255,0.7) !important; border-radius: 0 50px 50px 0; margin-right: 1rem; transition: none !important; }
    .nav-link:hover { color: #fff !important; background-color: rgba(255,255,255,0.1); }
    .nav-link.active { background-color: var(--admin-pink) !important; color: #fff !important; font-weight: bold; }
  </style>
</head>
<body class="bg-light">
  <div class="d-flex">
    <%- include('../partials/admin-sidebar') %>

    <main class="w-100" style="margin-left: 260px;">
      <div class="p-4">
        <div id="admin-viewport" class="bg-white rounded-4 shadow-sm p-4" style="min-height: calc(100vh - 48px);">
          <% if (success_msg && success_msg.length > 0) { %>
            <div class="alert alert-success"><%= success_msg %></div>
          <% } %>
          <% if (error_msg && error_msg.length > 0) { %>
            <div class="alert alert-danger"><%= error_msg %></div>
          <% } %>
          <%- body %>
        </div>
      </div>
    </main>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/admin.js"></script>
</body>
</html>