<div class="container py-5">
  <h2 class="fw-bold mb-4">Your Cart</h2>

  <% if (!cart || cart.length === 0) { %>
    <div class="text-center py-5">
      <i class="fa-solid fa-cart-shopping fa-4x text-muted mb-3"></i>
      <h4>Your cart is empty</h4>
      <a href="/products" class="btn btn-info text-white mt-3">Continue Shopping</a>
    </div>
  <% } else { %>
    <!-- Bảng sản phẩm chiếm toàn bộ chiều rộng -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead class="bg-body-secondary">
            <tr class="small text-muted text-uppercase">
              <th class="py-3 px-4 border-0">Product</th>
              <th class="py-3 border-0">Price</th>
              <th class="py-3 border-0">Quantity</th>
              <th class="py-3 border-0 text-end">Subtotal</th>
              <th class="py-3 border-0 text-center">Action</th>
            </tr>
          </thead>
          <tbody>
            <% cart.forEach(item => { %>
            <tr class="border-bottom" data-id="<%= item.product._id %>">
              <td class="py-4 px-4">
                <div class="d-flex align-items-center gap-3">
                  <img src="<%= item.product.imageUrl %>" alt="<%= item.product.name %>" class="rounded-3 border" style="width: 80px; height: 80px; object-fit: contain;">
                  <span class="fw-bold small"><%= item.product.name %></span>
                </div>
              </td>
              <td class="text-muted small price">$<%= item.product.salePrice.toFixed(2) %></td>
              <td>
                <input type="number" class="form-control form-control-sm cart-quantity-input" style="width: 70px;" value="<%= item.quantity %>" min="1" data-id="<%= item.product._id %>">
              </td>
              <td class="text-end fw-bold item-subtotal">$<%= (item.product.salePrice * item.quantity).toFixed(2) %></td>
              <td class="text-center">
                <form action="/orders/cart/remove/<%= item.product._id %>" method="POST" class="d-inline remove-form">
                  <button type="submit" class="btn btn-sm text-danger"><i class="fa-solid fa-trash-can"></i></button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Hàng dưới cùng: nút Continue/Update bên trái, tổng & checkout bên phải -->
    <div class="row align-items-center">
      <div class="col-md-6">
        <a href="/products" class="btn btn-outline-secondary rounded-pill px-4 py-2 fw-bold me-2">Continue Shopping</a>
        <button id="update-cart-btn" class="btn btn-primary rounded-pill px-4 py-2 fw-bold">Update Cart</button>
      </div>
      <div class="col-md-6 text-end">
        <div class="d-flex justify-content-end align-items-center gap-3">
          <span class="fw-bold fs-5">Cart total: $<span id="cart-total"><%= cart.reduce((sum, i) => sum + i.product.salePrice * i.quantity, 0).toFixed(2) %></span></span>
          <a href="/orders/checkout" class="btn btn-warning rounded-pill px-4 py-2 fw-bold shadow-sm">PROCEED TO CHECKOUT</a>
        </div>
      </div>
    </div>
  <% } %>
</div>

<script>
  (function() {
    // Xóa sản phẩm bằng AJAX
    document.querySelectorAll('.remove-form').forEach(form => {
      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        const res = await fetch(this.action, { method: 'POST' });
        if (res.ok) {
          location.reload();
        }
      });
    });

    // Nút Update Cart
    document.getElementById('update-cart-btn').addEventListener('click', async function() {
      const inputs = document.querySelectorAll('.cart-quantity-input');
      const updates = [];
      inputs.forEach(input => {
        updates.push({
          id: input.dataset.id,
          quantity: input.value
        });
      });

      // Gửi từng cập nhật lên server
      for (let update of updates) {
        await fetch(`/orders/cart/update/${update.id}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ quantity: update.quantity })
        });
      }

      // Sau khi cập nhật xong, reload lại trang để hiển thị tổng mới
      location.reload();
    });
  })();
</script>